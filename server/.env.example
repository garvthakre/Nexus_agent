 
 
AI_PROVIDER=groq

# ── Groq API (FREE — get key at console.groq.com) ───────────
GROQ_API_KEY=your_groq_api_key_here
# Available free models:
#   llama-3.3-70b-versatile  ← recommended (smart + fast)
#   llama-3.1-8b-instant     ← fastest
#   mixtral-8x7b-32768       ← good alternative
#   gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (paid) ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# ── OpenAI (paid) ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── Safety ──────────────────────────────────────────────────
MAX_SHELL_COMMAND_LENGTH=500
ALLOW_SHELL_COMMANDS=true
ALLOW_BROWSER_AUTOMATION=true
ALLOW_FILE_OPERATIONS=true

# ── Google Gemini (FREE — get key at aistudio.google.com) ───
# Used for Vision Tier 5 fallback in browser automation
# Free tier: 1,500 requests/day — no credit card required
# Sign in at https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Model used for vision (screenshot analysis):
GEMINI_VISION_MODEL=gemini-1.5-flash
