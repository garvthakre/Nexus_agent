      { "capability": "browser_extract_results", "parameters": { "variable_name": "products", "count": 5 }, "safety_risk": "low" },
      { "capability": "browser_open", "parameters": { "url": "{{products_0_url}}" }, "safety_risk": "low" }
    ]
  },
